# Firebase 설정 (Firebase Console에서 프로젝트 생성 후 값을 복사)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# 관리자 인증 (둘 중 하나 이상 설정)
ADMIN_PASSWORD=your-admin-password
# ADMIN_TOKEN=your-long-secret-token

# Firebase Admin SDK (관리자 로그인용 custom token 생성)
# 방법 1: 서비스 계정 키 JSON 경로
# GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account.json
# 방법 2: JSON 내용을 문자열로 (Vercel 등 배포 환경)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# (선택) 배포 URL
# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# (선택) 문자 발송 - true일 때만 실제 발송
# SMS_ENABLED=false
