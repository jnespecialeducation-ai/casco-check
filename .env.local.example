# Firebase 설정 (필수 - Firebase Console에서 프로젝트 생성 후 값을 복사)
# 프로젝트 설정 > 일반 > 앱 추가 > 웹 앱 선택 > 설정 값 복사
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# 관리자 인증 (둘 중 하나 이상 설정)
ADMIN_PASSWORD=your-admin-password
# ADMIN_TOKEN=your-long-secret-token

# Firebase Admin SDK (관리자 로그인용)
GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account.json
# 또는 FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# (선택) 로컬 개발 시 base URL
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# (선택) 문자 발송 - 알리고 API https://smartsms.aligo.in
# SMS_ENABLED=true
# ALIGO_API_KEY=알리고_API_키
# ALIGO_USER_ID=알리고_로그인_아이디
# ALIGO_SENDER=01012345678
# ALIGO_TESTMODE=true  # 테스트모드(Y): 과금/실발송 없이 연동 테스트
